generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  owner
  admin
  user
}

enum TeamRole {
  leader
  elder
  member
}

enum ProjectStatus {
  pending
  cloning
  ready
  building
  running
  failed
  stopped
}

enum HealthStatus {
  healthy
  unhealthy
  unknown
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  password           String
  name               String
  avatarUrl          String?
  platformRole       PlatformRole @default(user)
  mustChangePassword Boolean      @default(true)
  githubId           String?      @unique
  githubUsername      String?
  githubAccessToken   String?
  emailNotifications Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  teamMembers        TeamMember[]
  projectAssignments ProjectAssignment[]
  deploymentHistory  DeploymentHistory[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String
  teamId   String
  role     TeamRole
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Project {
  id             String        @id @default(uuid())
  teamId         String
  name           String
  slug           String
  repoUrl        String
  dockerfilePath String        @default("Dockerfile")
  status         ProjectStatus @default(pending)
  healthStatus   HealthStatus  @default(unknown)
  port           Int?
  containerId    String?
  restartCount   Int           @default(0)
  exitCode       Int?
  deployLogs     String?
  webhookSecret  String?       // HMAC secret for verifying GitHub webhook payloads
  cpuLimit       String?       // e.g. "0.5", "1.0" — maps to --cpus flag
  memoryLimit    String?       // e.g. "512m", "1g" — maps to --memory flag
  replicaCount   Int           @default(1) // number of container replicas to run (1–5)
  customDomain   String?       // e.g. "api.mycompany.com" — user-owned domain
  deployTarget   String        @default("docker")  // "docker" | "coolify"
  coolifyAppId   String?       // Coolify application UUID (set after first deploy to Coolify)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  envVars           EnvVar[]
  assignments       ProjectAssignment[]
  deploymentHistory DeploymentHistory[]
  replicas          ProjectReplica[]

  @@unique([teamId, slug])
}

model ProjectReplica {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  replicaIndex Int      // 0-based index: 0, 1, 2...
  containerId  String?
  port         Int?
  status       String   @default("stopped") // running | stopped | failed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, replicaIndex])
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  projectId  String
  userId     String
  assignedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model EnvVar {
  id        String   @id @default(uuid())
  projectId String
  key       String
  value     String   @default("")
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
}

model PlatformConfig {
  id              String   @id @default("singleton")
  coolifyUrl      String?  // e.g. "https://coolify.mycompany.com"
  coolifyApiToken String?  // Coolify API token — encrypted
  updatedAt       DateTime @updatedAt
}

model DeploymentHistory {
  id           String   @id @default(uuid())
  projectId    String
  imageTag     String
  deployLogs   String?
  deployedAt   DateTime @default(now())
  deployedBy   String
  isActive     Boolean  @default(false)
  deployNumber Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [deployedBy], references: [id], onDelete: SetDefault)

  @@unique([projectId, deployNumber])
}
