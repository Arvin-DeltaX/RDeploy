# Database
DATABASE_URL=postgresql://rdeploy:password@localhost:5432/rdeploy

# JWT — 7 day expiry, no refresh tokens
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# GitHub OAuth (for optional GitHub connect feature)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://rdeploy.deltaxs.co/api/auth/github/callback

# Workspace — where repos are cloned and .env files are written
# Production: /var/rdeploy/workspaces
# Development: .rdeploy/workspaces (gitignored)
RDEPLOY_WORKSPACE_DIR=/var/rdeploy/workspaces

# Domain
RDEPLOY_DOMAIN=deltaxs.co
RDEPLOY_PLATFORM_URL=https://rdeploy.deltaxs.co

# Frontend → Backend API URL
# Production: https://rdeploy.deltaxs.co (Traefik routes /api/* to backend)
# Development: http://localhost:5000
NEXT_PUBLIC_API_URL=https://rdeploy.deltaxs.co

# Seed owner account
SEED_OWNER_PASSWORD=changeme

# Default password assigned to newly created users (they must change it on first login)
DEFAULT_USER_PASSWORD=changeme

# Encryption — AES-256-GCM via Node crypto (no extra dependency)
# Must be exactly 32 bytes. Used for env var values and GitHub access tokens.
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Port range for deployed project containers
# Sequential scan: lowest free port in range assigned at deploy time
# Default range supports up to 1000 simultaneous deployed projects
PORT_RANGE_START=3001
PORT_RANGE_END=4000

# Docker network — all platform services and user containers join this network
# Traefik auto-discovers containers on this network via Docker socket + labels
DOCKER_NETWORK=rdeploy-net
